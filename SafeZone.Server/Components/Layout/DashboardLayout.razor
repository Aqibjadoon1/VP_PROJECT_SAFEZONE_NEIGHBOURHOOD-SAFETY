@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation
@inject AuthenticationStateProvider Auth
@inject IJSRuntime JS

<div class="dashboard-theme-shell" style="display:flex;min-height:100vh;">
    <div class="ambient-glow-2"></div>

    <aside class="dashboard-theme-sidebar @(_sidebarOpen ? "is-open" : "")" style="width:280px;flex-shrink:0;position:sticky;top:0;height:100vh;">
        <a href="@HomeHref" class="dashboard-theme-logo">
            <span class="dashboard-theme-logo-mark">SZ</span>
            <span>
                <span class="dashboard-theme-logo-title">SafeZone</span>
                <span class="dashboard-theme-logo-subtitle">Protected workspace</span>
            </span>
        </a>

        <AppSidebar Role="@Role" />

        <div class="dashboard-theme-sidebar-footer">
            SafeZone v1.0 &middot; Protected
        </div>
    </aside>

    @if (_sidebarOpen)
    {
        <button type="button" class="dashboard-theme-overlay is-open" @onclick="ToggleSidebar" aria-label="Close menu"></button>
    }

    <main class="dashboard-theme-main @(_sidebarOpen ? "sidebar-shifted" : "")" style="flex:1;min-width:0;" @onclick="CloseSidebarOnOutsideTap">
        <StatusBar />
        <header class="dashboard-theme-topbar">
            <div class="dashboard-theme-topbar-title">
                <button type="button" class="dashboard-theme-menu-button" @onclick="ToggleSidebar" title="Toggle menu" aria-label="Toggle menu">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>
                <div>
                    <h2>@TopbarTitle</h2>
                    <p>Welcome back to SafeZone, @DisplayName</p>
                </div>
            </div>

            <div class="dashboard-theme-user">
                @if (Role == "Resident")
                {
                    <button type="button" class="dashboard-theme-icon-button" title="Notifications" @onclick="GoToNotifications" aria-label="Notifications">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0"></path>
                        </svg>
                    </button>
                }

                <div class="dashboard-theme-avatar">@Initials</div>
                <div class="dashboard-theme-user-meta">
                    <span class="dashboard-theme-user-name">@DisplayName</span>
                    <span class="dashboard-theme-user-role">@Role</span>
                </div>

                <button type="button" class="btn btn-secondary btn-sm dashboard-theme-logout" @onclick="Logout">
                    Logout
                </button>
            </div>
        </header>

        <section class="dashboard-theme-content">
            @Body
        </section>
    </main>
</div>

<Toast />

@code {
    private string DisplayName = "User";
    private string Role = "Resident";
    private string Initials = "U";
    private bool _sidebarOpen;
    private Timer? _sessionTimer;
    private bool _disposed;

    private bool IsAuthority => Role is "Authority" or "SuperAdmin";
    private string TopbarTitle => IsAuthority ? "Command Center" : "Dashboard";
    private string HomeHref => IsAuthority ? "/authority/board" : "/user/dashboard";

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var user = state.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            DisplayName = user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "User";
            Role = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Resident";
            Initials = GetInitials(DisplayName);
            StartSessionCheck();
        }
    }

    private static string GetInitials(string displayName)
    {
        var parts = displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length > 1)
            return $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
        return string.IsNullOrWhiteSpace(displayName) ? "U" : displayName[..1].ToUpperInvariant();
    }

    private void ToggleSidebar()
    {
        _sidebarOpen = !_sidebarOpen;
    }

    private void CloseSidebarOnOutsideTap()
    {
        if (_sidebarOpen) _sidebarOpen = false;
    }

    private void StartSessionCheck()
    {
        _sessionTimer?.Dispose();
        _sessionTimer = new Timer(async _ =>
        {
            if (_disposed) return;
            try
            {
                await InvokeAsync(() =>
                {
                    if (_disposed) return;
                    _sessionTimer?.Dispose();
                    Navigation.NavigateTo("/blazor-logout?expired=true", true);
                });
            }
            catch (ObjectDisposedException) { }
        }, null, TimeSpan.FromMinutes(15), Timeout.InfiniteTimeSpan);
    }

    private void GoToNotifications()
    {
        Navigation.NavigateTo("/user/notifications");
    }

    private async Task Logout()
    {
        _sessionTimer?.Dispose();
        _sessionTimer = null;
        await JS.InvokeVoidAsync("window.location.replace", "/blazor-logout");
    }

    public void Dispose()
    {
        _disposed = true;
        _sessionTimer?.Dispose();
    }
}
