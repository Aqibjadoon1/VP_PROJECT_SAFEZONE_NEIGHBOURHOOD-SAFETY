@page "/authority/kanban"
@layout DashboardLayout
@attribute [Authorize(Roles = "Authority,Admin,SuperAdmin")]
@inject IIncidentService IncidentService
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthState

<PageTitle>Kanban Board - SafeZone</PageTitle>

<div class="max-w-7xl mx-auto pb-8 px-4">
    <div class="mb-8 pt-6">
        <PageHeader Title="Kanban Board" Subtitle="Drag & drop incident management" />
    </div>

    @if (isLoading)
    {
        <div class="kanban-board">
            @for (int i = 0; i < 5; i++)
            {
                <div class="kanban-column" style="--column-accent: var(--text-3);">
                    <div class="kanban-column-header">
                        <span class="kanban-column-title">Loading...</span>
                        <span class="kanban-column-count">0</span>
                    </div>
                    <div class="kanban-column-body">
                        <LoadingSkeleton Type="card" />
                        <LoadingSkeleton Type="card" />
                        <LoadingSkeleton Type="card" />
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="kanban-board">
            @foreach (IncidentStatus status in Enum.GetValues<IncidentStatus>())
            {
                var incidents = GetByStatus(status);
                <div class="kanban-column" style="min-height: 400px; display: flex; flex-direction: column; background: var(--bg-surface); border: 1px solid var(--glass-border); border-radius: var(--radius-lg); overflow: hidden; position: relative;">
                    <div style="position: absolute; top: 0; left: 0; right: 0; height: 3px; background: @GetStatusColor(status); opacity: 0.8;"></div>
                    <div class="kanban-column-header">
                        <span class="kanban-column-title">@GetStatusLabel(status)</span>
                        <span class="kanban-column-count">@incidents.Count</span>
                    </div>
                    <div class="kanban-column-body">
                        @if (incidents.Count == 0)
                        {
                            <div class="kanban-empty">
                                <span class="d-block fw-500" style="font-size: 0.9rem;">No incidents</span>
                            </div>
                        }
                        @foreach (var inc in incidents)
                        {
                            <div class="kanban-card @(justMovedId == inc.IncidentId ? "just-moved" : "")" style="position: relative; padding: 14px 12px; background: var(--bg-surface); border: 1px solid var(--glass-border); border-radius: var(--radius-md); margin-bottom: 10px; cursor: pointer; overflow: hidden;" @onclick='() => OpenMoveModal(inc)'>
                                <div style="position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: @GetSeverityColor(inc.Severity); opacity: 0.6;"></div>
                                <div style="font-weight: 600; font-size: 12px; line-height: 1.4; color: var(--text-1); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 10px; padding-left: 8px; min-height: 34px;">@inc.Title</div>
                                <div style="display: flex; align-items: center; justify-content: space-between; padding-left: 8px; gap: 8px;">
                                    <span style="font-family: var(--font-mono); font-size: 10px; color: var(--text-3); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1;">#@inc.IncidentNumber</span>
                                    <span style="font-size: 14px; opacity: 0.6; flex-shrink: 0;">@inc.CategoryIcon</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showModal && selectedIncident is not null)
{
    <div class="modal-overlay" @onclick='() => CloseModal()'>
        <div class="kanban-modal-card" @onclick:stopPropagation>
            <button class="modal-close" style="position: absolute; top: 12px; right: 16px; background: none; border: none; font-size: 1.4rem; cursor: pointer; color: var(--text-2);" @onclick='() => CloseModal()'>&times;</button>

            <div class="mb-3">
                <h3 class="font-display fw-600 text-lg" style="color: var(--text-1);">Move Incident</h3>
                <p class="fw-500 mt-1" style="color: var(--text-2); font-size: 14px;">@selectedIncident.Title</p>
                <span class="badge mt-2" style="background: @GetStatusColor(selectedIncident.Status); color: #fff;">@GetStatusLabel(selectedIncident.Status)</span>
            </div>

            <div class="mt-4">
                <p class="text-sm mb-3" style="color: var(--text-3);">Move to:</p>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var transition in AvailableTransitions(selectedIncident.Status))
                    {
                        <button class="btn font-display fw-500 text-sm px-4 py-2 rounded-xl" style="background: @GetStatusColor(transition); color: #fff; border: none; cursor: pointer;" @onclick='() => MoveTo(transition)'>
                            @GetStatusLabel(transition)
                        </button>
                    }
                    @if (AvailableTransitions(selectedIncident.Status).Count == 0)
                    {
                        <p class="text-sm" style="color: var(--text-3);">No transitions available</p>
                    }
                </div>
            </div>

            <div class="mt-4 pt-3" style="border-top: 1px solid var(--glass-border);">
                <button class="btn font-display fw-500 text-sm px-4 py-2 rounded-xl" style="background: rgba(255,255,255,0.06); color: var(--text-2); border: none; cursor: pointer;" @onclick='() => CloseModal()'>Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private List<IncidentListDto> allIncidents = [];
    private IncidentListDto? selectedIncident;
    private Guid justMovedId;
    private bool showModal;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try { allIncidents = await IncidentService.GetAllIncidentsAsync(); }
        catch { }
        finally { isLoading = false; }
    }

    private List<IncidentListDto> GetByStatus(IncidentStatus status) =>
        allIncidents.Where(i => i.Status == status).OrderByDescending(i => i.ReportedAt).ToList();

    private string GetSeverityColor(SeverityLevel s) => s switch
    {
        SeverityLevel.Low => "#00FF88",
        SeverityLevel.Medium => "#FFB800",
        SeverityLevel.High => "#FF6B35",
        SeverityLevel.Critical => "#FF3B5C",
        _ => "#666"
    };

    private void OpenMoveModal(IncidentListDto inc) { selectedIncident = inc; showModal = true; }
    private void CloseModal() { showModal = false; selectedIncident = null; }

    private List<IncidentStatus> AvailableTransitions(IncidentStatus current) => current switch
    {
        IncidentStatus.Pending => [IncidentStatus.Assigned, IncidentStatus.InProgress],
        IncidentStatus.Assigned => [IncidentStatus.InProgress, IncidentStatus.Pending],
        IncidentStatus.InProgress => [IncidentStatus.Resolved, IncidentStatus.Assigned],
        IncidentStatus.Resolved => [IncidentStatus.Closed, IncidentStatus.InProgress],
        IncidentStatus.Closed => [],
        _ => []
    };

    private async Task MoveTo(IncidentStatus newStatus)
    {
        if (selectedIncident == null) return;
        try
        {
            var state = await AuthState.GetAuthenticationStateAsync();
            var userIdClaim = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            Guid? uid = userIdClaim is not null && Guid.TryParse(userIdClaim, out var u) ? u : null;
            await IncidentService.UpdateStatusAsync(selectedIncident.IncidentId, newStatus, uid);
            allIncidents = await IncidentService.GetAllIncidentsAsync();
            justMovedId = selectedIncident.IncidentId;
            CloseModal();
            await Task.Delay(600);
            justMovedId = Guid.Empty;
        }
        catch { }
    }

    private string GetStatusColor(IncidentStatus s) => s switch
    {
        IncidentStatus.Pending => "var(--warning-amber)",
        IncidentStatus.Assigned => "var(--neon-green)",
        IncidentStatus.InProgress => "var(--command-purple)",
        IncidentStatus.Resolved => "var(--electric-cyan)",
        IncidentStatus.Closed => "var(--text-2)",
        _ => "var(--text-2)"
    };

    private string GetStatusLabel(IncidentStatus s) => s switch
    {
        IncidentStatus.Pending => "Pending",
        IncidentStatus.Assigned => "Assigned",
        IncidentStatus.InProgress => "In Progress",
        IncidentStatus.Resolved => "Resolved",
        IncidentStatus.Closed => "Closed",
        _ => s.ToString()
    };
}
