@page "/not-found"

<div class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center max-w-md">
        <div class="text-6xl font-display font-extrabold mb-4" style="color: var(--danger);">404</div>
        <h1 class="font-display text-3xl font-bold mb-4">Page Not Found</h1>
        <p class="text-muted text-lg mb-8">The page you're looking for doesn't exist or has been moved.</p>
        <div class="flex gap-4 justify-center">
            <a href="/" class="btn btn-primary">Go Home</a>
            <a href="/user/dashboard" class="btn btn-secondary">Dashboard</a>
        </div>
    </div>
</div>
